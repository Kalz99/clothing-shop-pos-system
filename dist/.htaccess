# Passenger (Node API only)
PassengerAppRoot "/home/luxncard/lazaro.luxn.lk/server"
PassengerBaseURI "/api"
PassengerNodejs "/home/luxncard/nodevenv/lazaro.luxn.lk/server/22/bin/node"
PassengerAppType node
PassengerStartupFile index.js

# ENV VARS
<IfModule Litespeed>
    SetEnv DB_HOST localhost
    SetEnv DB_NAME luxncard_clothing_pos
    SetEnv DB_PASSWORD admin@2026
    SetEnv NODE_ENV production
    SetEnv DB_USER luxncard_pos_admin
</IfModule>

# Handle React Router (SPA)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Skip rewrite if the request is for the API
    RewriteCond %{REQUEST_URI} ^/api [NC]
    RewriteRule .* - [L]

    # 2. Skip rewrite if it's index.html
    RewriteRule ^index\.html$ - [L]

    # 3. Check if the requested file/directory/link exists
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-l

    # 4. If nothing is found, send to index.html for React Router
    RewriteRule . /index.html [L]
</IfModule>

# Optional: Disable directory listing
Options -Indexes

# Security Headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"

    # Prevent caching of index.html so updates are seen immediately
    <FilesMatch "index\.html">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </FilesMatch>
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css application/xml application/xhtml+xml application/rss+xml application/javascript application/x-javascript
</IfModule>
